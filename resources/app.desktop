[Desktop Entry]
Name=World Clock
Comment=World clock panel applet for the COSMIC desktop
Type=Application
Icon=io.github.Drodofsky.CosmicAppletWorldClock
Exec=cosmic-applet-world-clock %F
Terminal=false
StartupNotify=true
Categories=COSMIC
Keywords=COSMIC
NoDisplay=true
X-CosmicApplet=true
X-CosmicShrinkable=true
X-HostWaylandDisplay=true
X-CosmicHoverPopup=Auto
MimeType=